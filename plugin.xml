<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <!-- ============================================================ -->
   <!--  Commands                                                    -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.commands">

      <command
         id="io.github.airwaves778899.claudecode.commands.openChatView"
         name="Open Claude Chat"
         description="Open Claude Chat view in Eclipse">
      </command>

      <command
         id="io.github.airwaves778899.claudecode.commands.openChatViewForProject"
         name="Open Claude Chat Here"
         description="Open Claude Chat view at selected project">
      </command>

      <command
         id="io.github.airwaves778899.claudecode.commands.askClaudeAboutSelection"
         name="Ask Claude about selection"
         description="Send selected code to Claude Chat">
      </command>

   </extension>

   <!-- ============================================================ -->
   <!--  Handlers                                                    -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.handlers">

      <handler
         commandId="io.github.airwaves778899.claudecode.commands.openChatView"
         class="io.github.airwaves778899.claudecode.handlers.OpenChatViewHandler">
      </handler>

      <handler
         commandId="io.github.airwaves778899.claudecode.commands.openChatViewForProject"
         class="io.github.airwaves778899.claudecode.handlers.OpenChatViewForProjectHandler">
      </handler>

      <handler
         commandId="io.github.airwaves778899.claudecode.commands.askClaudeAboutSelection"
         class="io.github.airwaves778899.claudecode.handlers.AskClaudeAboutSelectionHandler">
         <activeWhen>
            <with variable="activeEditor">
               <adapt type="org.eclipse.ui.texteditor.ITextEditor"/>
            </with>
         </activeWhen>
      </handler>

   </extension>

   <!-- ============================================================ -->
   <!--  Views                                                       -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.views">

      <view
         id="io.github.airwaves778899.claudecode.views.ClaudeTerminalView"
         name="Claude Chat"
         class="io.github.airwaves778899.claudecode.views.ClaudeTerminalView"
         allowMultiple="false">
      </view>

   </extension>

   <!-- ============================================================ -->
   <!--  Menus (toolbar + menu bar)                                  -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.menus">

      <!-- Toolbar button -->
      <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar id="io.github.airwaves778899.claudecode.toolbar">
            <command
               commandId="io.github.airwaves778899.claudecode.commands.openChatView"
               icon="icons/claude.png"
               tooltip="Open Claude Chat  (Alt+Shift+C)">
            </command>
         </toolbar>
      </menuContribution>

      <!-- Main menu bar -->
      <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=window">
         <menu id="io.github.airwaves778899.claudecode.menu" label="Claude">
            <command
               commandId="io.github.airwaves778899.claudecode.commands.openChatView"
               label="Open Claude Chat  (Alt+Shift+C)"
               icon="icons/claude.png">
            </command>
         </menu>
      </menuContribution>

      <!-- Editor right-click context menu: Ask Claude about selection -->
      <menuContribution locationURI="popup:org.eclipse.ui.popup.any?after=additions">
         <command
            commandId="io.github.airwaves778899.claudecode.commands.askClaudeAboutSelection"
            label="Ask Claude about selection"
            icon="icons/claude.png"
            style="push">
            <visibleWhen checkEnabled="false">
               <with variable="activeEditor">
                  <adapt type="org.eclipse.ui.texteditor.ITextEditor"/>
               </with>
            </visibleWhen>
         </command>
      </menuContribution>

   </extension>

   <!-- ============================================================ -->
   <!--  Popup Menus (Package/Project Explorer)                      -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.popupMenus">

      <!--
         adaptable="true"  is essential: Package/Project Explorer nodes
         are IAdaptable objects, not IProject directly.  Without this
         flag Eclipse skips the adapter chain and never matches.
      -->
      <objectContribution
         id="io.github.airwaves778899.claudecode.projectPopup"
         objectClass="org.eclipse.core.resources.IProject"
         adaptable="true">
         <action
            id="io.github.airwaves778899.claudecode.action.openChatHere"
            label="Open Claude Chat Here"
            icon="icons/claude.png"
            class="io.github.airwaves778899.claudecode.actions.OpenChatViewAction"
            enablesFor="+">
         </action>
         <action
            id="io.github.airwaves778899.claudecode.action.openCliTerminal"
            label="Open Claude CLI Terminal"
            icon="icons/claude.png"
            class="io.github.airwaves778899.claudecode.actions.OpenClaudeCliTerminalAction"
            enablesFor="1">
         </action>
      </objectContribution>

   </extension>

   <!-- ============================================================ -->
   <!--  Key Bindings                                                -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.bindings">

      <key
         commandId="io.github.airwaves778899.claudecode.commands.openChatView"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="M3+M2+C">
      </key>

   </extension>

   <!-- ============================================================ -->
   <!--  Preferences                                                 -->
   <!-- ============================================================ -->
   <extension point="org.eclipse.ui.preferencePages">
      <page
         id="io.github.airwaves778899.claudecode.preferences"
         name="Claude Code"
         class="io.github.airwaves778899.claudecode.preferences.ClaudePreferencePage">
      </page>
   </extension>

   <extension point="org.eclipse.core.runtime.preferences">
      <initializer
         class="io.github.airwaves778899.claudecode.preferences.ClaudePreferenceInitializer">
      </initializer>
   </extension>

</plugin>
