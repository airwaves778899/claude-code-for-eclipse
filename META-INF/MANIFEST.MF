Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: Claude Code for Eclipse
Bundle-SymbolicName: com.holtek.claudecode;singleton:=true
Bundle-Version: 1.0.0.qualifier
Bundle-Activator: com.holtek.claudecode.Activator
Require-Bundle: org.eclipse.ui,
